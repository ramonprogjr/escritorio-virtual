{
  "headers": [
    {
      "source": "/((?!_next/static|_next/image|sprites|avatars|icon|manifest\\.json).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/ciclos/gerente?ciclo=relatorio_manha",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/ciclos/diretor?ciclo=analise_manha",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/ciclos/diretor?ciclo=analise_noite",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/ciclos/diretor?ciclo=trafego",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/ciclos/atendente?ciclo=followup",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/ciclos/atendente?ciclo=sla",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/ml/ciclo?acao=kpis",
      "schedule": "5 * * * *"
    }
  ]
}
